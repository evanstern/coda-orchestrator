#!/usr/bin/env bash
#
# Notify active orchestrators when a new session is created.
# Env: CODA_SESSION_NAME, CODA_SESSION_DIR
#

ORCH_BASE_DIR="${CODA_ORCH_DIR:-$HOME/.config/coda/orchestrators}"

[ -d "$ORCH_BASE_DIR" ] || exit 0

for dir in "$ORCH_BASE_DIR"/*/; do
    [ -f "$dir/port" ] || continue

    port=$(cat "$dir/port")
    name=$(basename "$dir")
    session="${SESSION_PREFIX:-coda-}orch--${name}"

    tmux has-session -t "$session" 2>/dev/null || continue

    scope_file="$dir/scope.json"
    [ -f "$scope_file" ] || continue

    watch_patterns=$(jq -r '.watch[]' "$scope_file" 2>/dev/null)
    [ -n "$watch_patterns" ] || continue

    match=false
    while IFS= read -r pattern; do
        # shellcheck disable=SC2254
        case "${CODA_SESSION_NAME:-}" in $pattern) match=true ;; esac
    done <<< "$watch_patterns"

    $match || continue

    opencode run --attach "http://localhost:$port" \
        "[hook] New session created: ${CODA_SESSION_NAME:-unknown} at ${CODA_SESSION_DIR:-unknown}" \
        2>/dev/null &
done
